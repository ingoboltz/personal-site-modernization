---
const title = 'Academic record and transcripts';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="robots" content="index, follow" />
    <style>
      :global(*) {
        box-sizing: border-box;
      }

      :global(body) {
        margin: 0;
        background: #ffcc66;
        font-family: Arial, Helvetica, sans-serif;
        color: #000;
      }

      :global(a:link) {
        text-decoration: none;
        color: #cc3300;
      }

      :global(a:visited) {
        text-decoration: none;
        color: #cc3300;
      }

      :global(a:active) {
        text-decoration: none;
        color: red;
      }

      :global(a:hover) {
        text-decoration: underline;
        color: red;
      }

      .legacy-shell {
        width: 760px;
        border-collapse: collapse;
      }

      .spacer-cell {
        width: 10px;
      }

      .logo-cell {
        width: 150px;
        vertical-align: top;
      }

      .header-space {
        width: 600px;
        height: 75px;
      }

      .left-nav {
        vertical-align: top;
        width: 150px;
      }

      .main-content {
        vertical-align: top;
        padding-left: 8px;
      }

      .nav-list {
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .nav-list li {
        margin: 0 0 8px 0;
      }

      h2 {
        margin: 0.83em 0;
        font-size: 1.5em;
      }

      h3 {
        margin: 1em 0 0.35em;
        font-size: 1.17em;
      }

      p {
        margin: 0 0 1.2em;
      }
    </style>
  </head>
  <body>
    <table class="legacy-shell" border="0" cellpadding="0" cellspacing="0">
      <tr>
        <td class="spacer-cell"><img src="/img/spc.gif" alt="" width="10" height="1" /></td>
        <td class="logo-cell">
          <a href="/">
            <img src="/img/logo.gif" alt="" width="150" height="75" />
          </a>
        </td>
        <td class="header-space"><img src="/img/spc.gif" alt="" width="600" height="75" /></td>
      </tr>
      <tr>
        <td></td>
        <td class="left-nav">
          <ul class="nav-list">
            <li><a href="/">Home</a></li>
            <li><a href="/academic-record/">Academic record and transcripts</a></li>
            <li><a href="/i-files.html">I-Files</a></li>
          </ul>
        </td>
        <td class="main-content">
          <h2>Academic record and transcripts</h2>

          <h3>Master's degree transcript / grades</h3>
          <p>
            <a href="/certificate-tu.html">View legacy Master's degree transcript / grades</a>
          </p>

          <h3>U.S. exchange year transcript / grades</h3>
          <p>
            <a href="/certificate-bu.html">View legacy U.S. exchange year transcript / grades</a>
          </p>
        </td>
      </tr>
    </table>
  </body>
</html>
