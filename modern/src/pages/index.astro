---
import LegacyShellLayout from '../layouts/LegacyShellLayout.astro';

const title = 'Ingo Boltz Personal Homepage';
---

<LegacyShellLayout
  title={title}
  description="Ingo Boltz Personal Page: CV, Reports from Volunteering in Africa, Photos & Stories"
>
  <td class="hero-cell">
    <img
      class="hero-image"
      src="/img/ingo_face.jpg"
      alt="The Choice is yours"
      width="390"
      height="370"
    />
  </td>
  <td class="text-cell">
    <h2>Welcome to Time and Life of Ingo B!</h2>
    <h3>Made in 1997 - when the web was 1.0 :-)</h3>

    <span class="empty-line"></span>
    <span class="empty-line"></span>
    <span class="empty-line"></span>

    <h3>
      <a href="http://www.linkedin.com/in/ingoboltz" target="_blank" rel="noreferrer">
        My most recent CV is now on LinkedIn.
      </a>
    </h3>
    <h3><a href="/academic-record/">Academic record and transcripts.</a></h3>
    <h3><a href="/i-files.html">The old i-files. My personal museum.</a></h3>
  </td>
</LegacyShellLayout>

<style>
  .hero-cell {
    width: 390px;
    vertical-align: middle;
  }

  .hero-image {
    width: 390px;
    height: 370px;
    object-fit: cover;
    display: block;
  }

  .text-cell {
    vertical-align: top;
    padding-left: 8px;
  }

  h2 {
    margin: 0.83em 0;
    font-size: 1.5em;
  }

  h3 {
    margin: 1em 0;
    font-size: 1.17em;
  }

  .empty-line {
    display: block;
    height: 1.2em;
  }
</style>
